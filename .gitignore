########################################
# Root .gitignore (Monorepo)
########################################

########################################
# General / OS
########################################
*.log
.DS_Store
Thumbs.db
Desktop.ini
.history
tmp/
*.tmp
*.temp

########################################
# IDEs
########################################
.idea/
.vscode/
*.iml
*.ipr
*.iws

########################################
# Flutter (Client)
########################################
client/flutter/.dart_tool/
client/flutter/.flutter-plugins
client/flutter/.flutter-plugins-dependencies
client/flutter/.metadata
client/flutter/.packages
client/flutter/.pub-cache/
client/flutter/.pub/
client/flutter/build/
client/flutter/coverage/
client/flutter/client_dev.json
client/flutter/config/dev.json
client/flutter/rust_builder/

# Platform Specifics
client/flutter/android/local.properties
client/flutter/android/.gradle/
client/flutter/android/.cxx/
client/flutter/android/app/.cxx/
client/flutter/android/app/build/
client/flutter/android/**/build/
client/flutter/android/app/*.apk
client/flutter/android/app/*.aab
client/flutter/ios/Flutter/.last_build_id
client/flutter/ios/Flutter/ephemeral/
client/flutter/ios/DerivedData/
client/flutter/ios/Build/
client/flutter/macos/Flutter/ephemeral/
client/flutter/macos/Build/
client/flutter/windows/flutter/ephemeral/
client/flutter/windows/flutter/generated_plugin_registrant.cc
client/flutter/windows/flutter/generated_plugin_registrant.h
client/flutter/windows/flutter/generated_plugins.cmake
client/flutter/windows/runner/Debug/
client/flutter/windows/runner/Release/
client/flutter/windows/runner/RelWithDebInfo/
client/flutter/windows/runner/MinSizeRel/
client/flutter/windows/runner/**/CMakeFiles/
client/flutter/windows/runner/**/cmake_install.cmake
client/flutter/windows/runner/**/Makefile
client/flutter/windows/x64/
client/flutter/linux/flutter/ephemeral/
client/flutter/linux/flutter/generated_plugin_registrant.cc
client/flutter/linux/flutter/generated_plugin_registrant.h
client/flutter/linux/flutter/generated_plugins.cmake
client/flutter/linux/**/CMakeFiles/
client/flutter/linux/**/cmake_install.cmake
client/flutter/linux/**/Makefile

########################################
# Rust
########################################
client/rust/target/
server/rust/target/
shared/rust/target/
target/
**/*.rs.bk

########################################
# Scripts & Logs
########################################
server.log
tunnel.log

########################################
# Security / Credentials
########################################
.env
AGENTS.md
*.pem
*.keystore
*.jks
key.properties
client/flutter/keys/

########################################
# Additional common ignores
########################################
# Build outputs
build/
**/build/

# Tooling caches
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub/
.pub-cache/

# Gradle
.gradle/
**/.gradle/

# Node
node_modules/

# Python
__pycache__/
*.py[cod]
venv/
env/

# iOS / CocoaPods
client/flutter/ios/Pods/
client/flutter/ios/Runner.xcworkspace/
client/flutter/ios/Runner/GeneratedPluginRegistrant.h
client/flutter/ios/Runner/GeneratedPluginRegistrant.m

# macOS
.DS_Store

# Misc caches
.cache/
.idea/workspace.xml